# Copy this file to .env and fill in your real values.
# .env is git-ignored and will never be committed.

# Gmail address used to SEND alert emails
CLAUDE_MONITOR_FROM="you@gmail.com"

# Gmail App Password (NOT your regular Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
# Choose "Mail" as the app. It will look like: abcd efgh ijkl mnop
CLAUDE_MONITOR_GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Email address that receives the alerts (can be the same as above)
CLAUDE_MONITOR_TO="you@gmail.com"
